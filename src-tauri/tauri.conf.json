{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "queue-boss",
  "version": "0.1.0",
  "identifier": "com.queueboss.app",
  "build": {
    "beforeDevCommand": "ng serve",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "ng build",
    "frontendDist": "../dist/queue-boss/browser"
  },
  "app": {
    "windows": [
      {
        "title": "Queue Boss",
        "width": 1100,
        "height": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
